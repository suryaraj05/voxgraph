# Copy to .env and fill in your keys (never commit .env)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# LLM — gemini-flash-latest (auto-updated) or gemini-2.5-flash (stable)
GEMINI_MODEL=gemini-flash-latest

# TTS — pcm_24000 for live streaming; mp3_44100_128 for MP3 files
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
TTS_SAMPLE_RATE=24000

# Wait this many seconds after last audio before sending full question to LLM
UTTERANCE_DEBOUNCE_SEC=2.5

# Low-latency settings for LinkedIn / live demos (shorter debounce, faster endpointing)
# DEMO_MODE=1
# UTTERANCE_DEBOUNCE_SEC=0.6
# DEEPGRAM_ENDPOINTING_MS=150

# Set to 1 for STT-only (skips Gemini + ElevenLabs). Use 0 or omit for full pipeline.
STT_ONLY=0
